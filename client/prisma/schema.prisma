generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom Relation for the AI Resume Creator
  resumes       Resume[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Resume {
  id             String   @id @default(cuid())
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Storing the drafted resume data as JSON block for flexibility
  title          String   @default("My Resume")
  
  // Collected from Multi-Step Form
  qualifications String?
  experiences    String?
  projects       String?
  
  // Generated AI Output (Current active version)
  aiDraftContent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // New Relations
  versions    ResumeVersion[]
  assessments Assessment[]
  abTests     ABTest[]        @relation("PrimaryResume")
  abVariants  ABTest[]        @relation("VariantResume")
}

model ResumeVersion {
  id        String   @id @default(cuid())
  resumeId  String
  name      String?  // e.g. "Draft v1", "Post-FAANG Rewrite"
  content   String   // JSON string of the resume object
  createdAt DateTime @default(now())
  
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Assessment {
  id        String   @id @default(cuid())
  resumeId  String
  type      String   // RECRUITER, SKILL_GAP, HEATMAP, INTERVIEW_PREP, LINKEDIN
  data      String   // JSON string of the assessment results
  createdAt DateTime @default(now())
  
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ABTest {
  id              String   @id @default(cuid())
  primaryResumeId String
  variantResumeId String
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED
  metrics         String?  // JSON of comparison results
  createdAt       DateTime @default(now())

  primary   Resume   @relation("PrimaryResume", fields: [primaryResumeId], references: [id], onDelete: Cascade)
  variant   Resume   @relation("VariantResume", fields: [variantResumeId], references: [id], onDelete: Cascade)
}
